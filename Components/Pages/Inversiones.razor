@page "/inversiones"
@rendermode InteractiveServer
@using FinanzasApp.Models
@using FinanzasApp.Utils
@inject FinanzasApp.Services.FinanzasService FinanzasService

<PageTitle>Patrimonio</PageTitle>

@if (cargando)
{
<div class="loading-card">Cargando portafolio...</div>
}
else
{

<div class="page-shell">

<div class="page-header">
<h1>Patrimonio</h1>
<p>Ahorros, inversiones y crecimiento de capital</p>
</div>


<!-- KPIs -->

<div class="top-kpis">

<div class="kpi-card">
<span>Ahorros</span>
<strong>@MoneyFormatter.Formatear(totalAhorros)</strong>
</div>

<div class="kpi-card">
<span>Inversiones</span>
<strong>@MoneyFormatter.Formatear(totalInversiones)</strong>
</div>

<div class="kpi-card">
<span>Patrimonio total</span>
<strong>@MoneyFormatter.Formatear(totalAhorros + totalInversiones)</strong>
</div>

<div class="kpi-card">
<span>% ahorro</span>
<strong>@PorcentajeAhorros().ToString("N1")%</strong>
</div>

<div class="kpi-card">
<span>% inversión</span>
<strong>@PorcentajeInversiones().ToString("N1")%</strong>
</div>

</div>



<!-- AHORROS -->

<div class="panel">

<h3>Ahorros</h3>

<table class="budget-table">

<thead>
<tr>
<th>Cuenta</th>
<th>Valor</th>
<th>EA</th>
<th>Estimado</th>
<th>Fecha inicio</th>
<th>Meta</th>
<th>Progreso</th>
<th></th>
</tr>
</thead>

<tbody>

@foreach (var ahorro in ahorros)
{

var porcentaje = FinanzasService.CalcularPorcentajeMetaAhorro(ahorro);
var estimado = FinanzasService.CalcularValorEstimadoAhorro(ahorro);

<tr>

<td>@ahorro.Nombre</td>

<td>
<input type="number"
class="table-input"
@bind="ahorro.ValorActual"/>
</td>

<td>
<input type="number"
step="0.01"
class="table-input"
@bind="ahorro.TasaEA"/>
</td>

<td>
@MoneyFormatter.Formatear(estimado)
</td>

<td>
<input type="date"
class="table-input"
@bind="ahorro.FechaInicio"/>
</td>

<td>
<input type="number"
class="table-input"
@bind="ahorro.MetaObjetivo"/>
</td>

<td>

<div class="progress-bar">
<div class="progress-fill" style="width:@porcentaje%"></div>
</div>

@porcentaje %

</td>

<td>

<button class="btn-soft"
@onclick="() => GuardarAhorroEditado(ahorro)">
Guardar
</button>

<button class="btn-danger"
@onclick="() => EliminarAhorro(ahorro.Id)">
Eliminar
</button>

</td>

</tr>

}

</tbody>

</table>

</div>



<!-- INVERSIONES -->

<div class="panel">

<h3>Inversiones</h3>

<table class="budget-table">

<thead>
<tr>
<th>Activo</th>
<th>Tipo</th>
<th>Capital inicial</th>
<th>Valor actual</th>
<th>EA</th>
<th>Estimado</th>
<th>Fecha inicio</th>
<th></th>
</tr>
</thead>

<tbody>

@foreach (var inv in inversiones)
{

var estimado = FinanzasService.CalcularValorEstimado(inv);

<tr>

<td>@inv.Nombre</td>

<td>
<select class="table-input" @bind="inv.Tipo">
<option>CDT</option>
<option>FIC</option>
<option>Acción</option>
<option>ETF</option>
<option>Bonos</option>
<option>Cripto</option>
</select>
</td>

<td>
<input type="number"
class="table-input"
@bind="inv.CapitalInicial"/>
</td>

<td>
<input type="number"
class="table-input"
@bind="inv.ValorActual"/>
</td>

<td>
<input type="number"
step="0.01"
class="table-input"
@bind="inv.TasaEA"/>
</td>

<td>
@MoneyFormatter.Formatear(estimado)
</td>

<td>
<input type="date"
class="table-input"
@bind="inv.FechaInicio"/>
</td>

<td>

<button class="btn-soft"
@onclick="() => GuardarInversionEditada(inv)">
Guardar
</button>

<button class="btn-danger"
@onclick="() => EliminarInversion(inv.Id)">
Eliminar
</button>

</td>

</tr>

}

</tbody>

</table>

</div>



<!-- CREAR AHORRO -->

<div class="panel">

<h3>Registrar ahorro</h3>

<div class="form-grid">

<div class="field">
<label>Nombre</label>
<input class="input"
placeholder="Ej: Cajita Nubank"
@bind="nuevoAhorro.Nombre"/>
</div>

<div class="field">
<label>Tipo</label>

<select class="input"
@bind="nuevoAhorro.Tipo">

<option>Cajita</option>
<option>Cuenta alto rendimiento</option>
<option>Fondo de emergencia</option>
<option>Cuenta ahorro bancaria</option>
<option>Ahorro objetivo</option>

</select>

</div>

<div class="field">
<label>Valor actual</label>
<input type="number"
class="input"
@bind="nuevoAhorro.ValorActual"/>
</div>

<div class="field">
<label>Meta objetivo</label>
<input type="number"
class="input"
@bind="nuevoAhorro.MetaObjetivo"/>
</div>

<div class="field">
<label>Tasa EA (%)</label>
<input type="number"
step="0.01"
class="input"
@bind="nuevoAhorro.TasaEA"/>
</div>

<div class="field">
<label>Fecha inicio</label>
<input type="date"
class="input"
@bind="nuevoAhorro.FechaInicio"/>
</div>

</div>

<br/>

<button class="btn-primary"
@onclick="GuardarAhorro">
Guardar ahorro
</button>

</div>



<!-- CREAR INVERSION -->

<div class="panel">

<h3>Registrar inversión</h3>

<div class="form-grid">

<div class="field">
<label>Nombre</label>
<input class="input"
placeholder="Ej: FIC Tyba"
@bind="nuevaInversion.Nombre"/>
</div>

<div class="field">
<label>Tipo</label>

<select class="input"
@bind="nuevaInversion.Tipo">

<option>CDT</option>
<option>FIC</option>
<option>Acción</option>
<option>ETF</option>
<option>Bonos</option>
<option>Cripto</option>

</select>

</div>

<div class="field">
<label>Capital inicial</label>
<input type="number"
class="input"
@bind="nuevaInversion.CapitalInicial"/>
</div>

<div class="field">
<label>Valor actual</label>
<input type="number"
class="input"
@bind="nuevaInversion.ValorActual"/>
</div>

<div class="field">
<label>Tasa EA (%)</label>
<input type="number"
step="0.01"
class="input"
@bind="nuevaInversion.TasaEA"/>
</div>

<div class="field">
<label>Fecha inicio</label>
<input type="date"
class="input"
@bind="nuevaInversion.FechaInicio"/>
</div>

</div>

<br/>

<button class="btn-primary"
@onclick="GuardarInversion">
Guardar inversión
</button>

</div>

</div>

}

@code {

bool cargando = true;

List<AhorroMeta> ahorros = new();
List<Inversion> inversiones = new();

AhorroMeta nuevoAhorro = new()
{
Tipo = "Cajita",
FechaInicio = DateTime.Today
};

Inversion nuevaInversion = new()
{
Tipo = "CDT",
FechaInicio = DateTime.Today
};

decimal totalAhorros;
decimal totalInversiones;

protected override async Task OnInitializedAsync()
{
await CargarTodo();
}

async Task CargarTodo()
{

ahorros = await FinanzasService.ObtenerAhorrosAsync();
inversiones = await FinanzasService.ObtenerInversionesAsync();

totalAhorros = ahorros.Sum(x => x.ValorActual);
totalInversiones = inversiones.Sum(x => x.ValorActual);

cargando = false;

}

async Task GuardarAhorro()
{

if (string.IsNullOrWhiteSpace(nuevoAhorro.Nombre))
return;

await FinanzasService.GuardarAhorroAsync(nuevoAhorro);

nuevoAhorro = new AhorroMeta
{
Tipo = "Cajita",
FechaInicio = DateTime.Today
};

await CargarTodo();

}

async Task GuardarInversion()
{

if (string.IsNullOrWhiteSpace(nuevaInversion.Nombre))
return;

await FinanzasService.GuardarInversionAsync(nuevaInversion);

nuevaInversion = new Inversion
{
Tipo = "CDT",
FechaInicio = DateTime.Today
};

await CargarTodo();

}

async Task GuardarAhorroEditado(AhorroMeta ahorro)
{
await FinanzasService.GuardarAhorroAsync(ahorro);
await CargarTodo();
}

async Task GuardarInversionEditada(Inversion inv)
{
await FinanzasService.GuardarInversionAsync(inv);
await CargarTodo();
}

decimal PorcentajeAhorros()
{

var total = totalAhorros + totalInversiones;

if (total == 0) return 0;

return totalAhorros / total * 100;

}

decimal PorcentajeInversiones()
{

var total = totalAhorros + totalInversiones;

if (total == 0) return 0;

return totalInversiones / total * 100;

}

async Task EliminarInversion(int id)
{
await FinanzasService.EliminarInversionAsync(id);
await CargarTodo();
}

async Task EliminarAhorro(int id)
{
await FinanzasService.EliminarAhorroAsync(id);
await CargarTodo();
}

}